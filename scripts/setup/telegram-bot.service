[Unit]
# 示例 systemd 服务，请按部署环境调整 User / WorkingDirectory / EnvironmentFile
Description=Fate-Engine Telegram Bot
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=fatecat
WorkingDirectory=/srv/fatecat/services/telegram
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=/etc/fatecat/fatecat.env
ExecStart=/bin/bash -lc 'source /srv/fatecat/.venv/bin/activate && python start.py bot'
Restart=always
RestartSec=5
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
